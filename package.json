{
  "name": "crypto-lab-isogeny-gate",
  "version": "1.0.0",
  "description": "Browser-based isogeny cryptography demo — elliptic curve isogenies, toy SIDH, Castryck-Decru attack, CSIDH, SQIsign",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "test:a11y": "playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.10.0",
    "gh-pages": "^6.3.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.7"
  }
}
